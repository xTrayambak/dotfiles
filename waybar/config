{
    "height": 35,
    "spacing": 5,
    "layer": "top",
    "modules-left": ["wlr/workspaces", "hyprland/window"],
    "modules-center": ["clock", "custom/notification"],
    "modules-right": ["custom/weather", "pulseaudio", "network", "cpu", "memory", "temperature", "battery", "tray"], 
    "tray": {
        "spacing": 10
    },
    "custom/weather": {
      "exec": "curl -s 'wttr.in/NOIDA?format=1'",
      "interval": 100,
      "format": "{}",
      "tooltip": false
    },
 "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
      "none": "яВв",
      "dnd-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
      "dnd-none": "яЗ╖",
      "inhibited-notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
      "inhibited-none": "яВв",
      "dnd-inhibited-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
      "dnd-inhibited-none": "яЗ╖"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
    "clock": {
        "format": "{:%d/%m/%Y %I:%M %p}"
    },
    "cpu": {
        "format": "{usage}% яЛЫ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% яФ╕"
    },
    "temperature": {
	"hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["яЛЛ", "яЛЙ", "яЛЗ"]
    },
    "backlight": {
        "format": "{percent}% тША",
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% {icon}",
        "format-plugged": "{capacity}% яЗж",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) яЗл",
        "format-disconnected": "Disconnected тЪа",
    },
    "pulseaudio": {
        "format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
    },
    "hyprland/window": {
    	"max-length": 48,
        "format": "{}",
        "separate-outputs": true
    },
    "wlr/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "яЙи",
            "2": "яДб",
            "3": "яДа",
            "urgent": "яБк",
            "default": "яДС"
      },
      "sort-by-number": true
      },
    }
}
